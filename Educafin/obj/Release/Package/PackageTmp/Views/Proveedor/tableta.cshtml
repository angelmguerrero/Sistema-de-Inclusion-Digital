
@model List<MvcApplication8.Models.Tableta>
@{
    ViewBag.Title = "tableta";
}



    <section class="p10"></section>

    <section class="container form-horizontal ">
        <div class="col-sm-11 col-sm-offset-1">
            <div class="form-group ">
                <div class="text-left ">
                    <h1>Tabletas</h1>
                    <h2>Registro</h2> </div>
            </div>
            <div class="form-group">
    @using (Html.BeginForm("tableta", "Proveedor", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
                <form name="importa" method="post" action="" enctype="multipart/form-data">
                    <div class="col-sm-6 col-sm-offset-2">
                        <label>Archivo de tabletas:</label>
                        <div class="input-group">
                            <span class="input-group-btn">
		<button id="fake-file-button-browse" type="button" class="btn botonf btnAlter">
			<span class="glyphicon glyphicon-file"></span>
                            </button>
                            </span>
                            <input type="file" id="files-input-upload" name="file" style="display:none" data-buttonBefore="true">
                            <input type="text" id="fake-file-input-name" disabled="disabled" placeholder="Archivo no seleccionado" class="form-control">
                            <span class="input-group-btn">

		<button type="submit" class="btn btnWarning" disabled="disabled" id="fake-file-button-upload" value="1" name="action">
			<span class="glyphicon glyphicon-upload"></span>
                            </button>
                            </span>
                        </div>
                    </div>
                </form>
       
                }
        <div class="form-group">

            <div class="col-sm-10 col-sm-offset-1">
                <table width=100% class="table  table-hover table-condensed table-striped" id="tablaLista" align="left">
                    <thead>
                        <tr class="bakinfo">
                            <td width="5%">
                                <h4>No.</h4></td>
                            <td width="30%">
                                <h4>Número de serie</h4></td>
                            <td width="40%">
                                <h4>Intitución</h4></td>
                            <td width="25%">
                                <h4>Estado</h4></td>
                        </tr>
                    </thead>
                    @foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.No)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.serie)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.nombre)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.estado)
        </td>

    </tr>
}

                </table>
            </div>

        </div>
    </section>
