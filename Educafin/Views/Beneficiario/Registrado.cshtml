
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Registrado";
}

<div>
    <div class="alert @TempData["error"]"> @TempData["message"]</div>
</div>

<div class="form-group">
    <div class="col-sm-3 col-sm-offset-4">
        <button type="button" onclick="location.href='@Url.Action("Index", "Home")'" class="btn boton btnDanger btn-lg btn-block">
            <span class="glyphicon glyphicon-remove"></span> Regresar
        </button>
    </div>
</div>

