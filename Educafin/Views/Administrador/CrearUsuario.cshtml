@model Educafin.Models.usuario

@{
    ViewBag.Title = "Create";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()


    <section class="container form-horizontal ">
        @*<div class="col-sm-11 col-sm-offset-1">*@
            <div class="form-group ">
                <div class="text-left ">
                    <h1>Usuario</h1>
                    <h2>Registro</h2>
                </div>
            </div>
            <div class="@TempData["error"]">
                @TempData["message"]
            </div>

            <div class="form-horizontal">
                
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <div class="form-group">

                    <div class="col-md-5">
                        <label class="control-label">CURP:</label>
                        @Html.EditorFor(model => model.CURP, new { htmlAttributes = new { @class = "form-control", @id= "curpUser" } })
                        @Html.ValidationMessageFor(model => model.CURP, "", new { @class = "text-danger" })
                    </div>
                
                    <div class="col-md-5 col-sm-offset-1">
                        <label class="control-label">Correo:</label>
                        @Html.EditorFor(model => model.correo, new { htmlAttributes = new { @class = "form-control" , placeholder = "example@mail.ex", @type = "email" } })
                        @Html.ValidationMessageFor(model => model.correo, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">

                    <div class="col-md-5">
                        <label class="control-label">Nombre(s):</label>
                        @Html.EditorFor(model => model.nombre, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.nombre, "", new { @class = "text-danger" })
                    </div>
               

                    <div class="col-md-3">
                        <label class="control-label">Apellido Paterno:</label>
                        @Html.EditorFor(model => model.apellido_pat, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.apellido_pat, "", new { @class = "text-danger" })
                    </div>
                
                    <div class="col-md-3">
                        <label class="control-label">Apellido Materno:</label>
                        @Html.EditorFor(model => model.apellido_mat, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.apellido_mat, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-sm-3">
                        <label class="control-label">Código postal:</label>
                        @Html.EditorFor(model => model.codigopostal, new { htmlAttributes = new { @class = "form-control", @type = "number", @max = "99999" } })
                        @Html.ValidationMessageFor(model => model.codigopostal, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-sm-4">
                        <label class="control-label">Estado:</label>
                        @Html.EditorFor(model => model.estado_r, new { htmlAttributes = new { @class = "form-control" , @id = "estado" } })
                        @Html.ValidationMessageFor(model => model.estado_r, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-sm-4">
                        <label class="control-label">Municipio:</label>
                        @Html.EditorFor(model => model.municipio, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.municipio, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-sm-3 ">
                        <label class="control-label">Colonia:</label>
                        <select class="form-control" name="colonia" id="colonia"></select>
                        @Html.ValidationMessageFor(model => model.colonia, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-sm-4">
                        <label class="control-label">Calle:</label>
                        @Html.EditorFor(model => model.calle, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.calle, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-2">
                        <label class="control-label">Numero Exterior:</label>
                        @Html.EditorFor(model => model.num_ext, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.num_ext, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-2">
                        <label class="control-label">Numero Interior:</label>
                        @Html.EditorFor(model => model.num_int, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.num_int, "", new { @class = "text-danger" })
                    </div>
                    
                 </div>

                <div class="form-group">

                    <div class="col-md-3">
                        <label class="control-label">Teléfono:</label>
                        @Html.EditorFor(model => model.telefono, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.telefono, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        <label class="control-label">Celular:</label>
                        @Html.EditorFor(model => model.celular, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.celular, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-sm-4">
                        <label class="control-label">Tipo de Usuario:</label>
                        <select name="tipo" id="tipo" class="form-control">
                            <option value="I">Institución</option>
                            <option value="P">Proveedor</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-5 col-sm-offset-3">
                        <label class="control-label">Proveedor o Institucion :</label>
                        @Html.EditorFor(model => model.pertenece, new { htmlAttributes = new { @class = "form-control" , @id = "Aupertenece" } })
                        @Html.ValidationMessageFor(model => model.pertenece, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-sm-3 col-sm-offset-2">
                        <button type="submit" class="btn boton btnPrimary btn-lg btn-block"><span class="glyphicon glyphicon-ok"></span> Registrar</button>
                    </div>
                    <div class="col-sm-3 col-sm-offset-1">

                        <button type="reset" onclick="location.href='@Url.Action("Usuarios","Administrador")'" class="btn boton btnDanger btn-lg btn-block"
                                id="reset">
                            <span class="glyphicon glyphicon-remove"></span> Cancelar
                        </button>



                    </div>
                </div>

                <br><br><br><br><br>



                <div class="form-group" style="display:none;">

                    <div class="col-md-2">
                        <label class="control-label">Estado de Nacimiento:</label>
                        @Html.EditorFor(model => model.estado_nac, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.estado_nac, "", new { @class = "text-danger" })
                    </div>


                    <div class="col-md-2">
                        <label class="control-label">Sexo:</label>
                        @Html.EditorFor(model => model.sexo, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.sexo, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-2">
                        <label class="control-label">Fecha de Nacimiento:</label>
                        @Html.EditorFor(model => model.fecha_nac, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.fecha_nac, "", new { @class = "text-danger" })
                    </div>
                
                    <div class="col-md-2">
                        <label class="control-label">Estatus:</label>
                        @Html.EditorFor(model => model.estatus, new { htmlAttributes = new { @class = "form-control", @id= "estatusAlt" ,@value="E" } })
                        @Html.ValidationMessageFor(model => model.estatus, "", new { @class = "text-danger" })
                    </div>
                </div>

                </div>
            @*</div>*@
        </section>
            }