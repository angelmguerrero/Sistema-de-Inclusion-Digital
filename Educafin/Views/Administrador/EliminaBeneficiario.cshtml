
@model List<Educafin.Models.Alumno>

@{
    ViewBag.Title = "ListaBeneficiario";

}


<body>
    <section class="container form-horizontal ">
        <div class="col-sm-11 col-sm-offset-1">
            <div class="form-group ">
                <div class="text-left ">
                    <h1>Beneficiarios</h1>
                    <h2>Registrados</h2>
                </div>
            </div>

            <div class="form-group">
                <div class="col-sm-4">
                    <button data-toggle="tooltip" title="Nuevo Alumnos" type="submit" class="btn botonM rota btnWarning btn-circle btn-lg" onclick="location.href='@Url.Action("RegistroUnico", "BenefiAdmin")'">
                        <i class="glyphicon glyphicon-plus"></i>
                    </button>
                </div>
                <div class="col-sm-4">
                    <button type="submit" class="btn boton btnPrimary btn-lg btn-block" onclick="location.href='@Url.Action("DownloadBeneficiario", "InstitucionBenefic")';">
                        <span class="glyphicon glyphicon-save"></span> Descargar Lista
                    </button>

                </div>

                <div class="col-sm-4">
                    <button type="submit" class="btn botonM btnAlter btn-lg btn-block" onclick="location.href='@Url.Action("RegistroBeneficiario", "BenefiAdmin")'">
                        <span class="glyphicon glyphicon-file"></span> Cargar archivo
                    </button>
                </div>
            </div>


            <div class="form-group">

                <table id="tabla" class="display" cellspacing="0" width="100%">
                    <thead>
                        <tr class="bakinfo">
                            <td width="5%">
                                <h4>No.</h4>
                            </td>

                            <td width="20%">
                                <h4>CURP</h4>
                            </td>
                            <td width="15%">
                                <h4>Matricula</h4>
                            </td>
                            <td width="30%">
                                <h4>Nombre</h4>
                            </td>
                            <td width="5%"></td>
                        </tr>
                    </thead>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.no)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.curp)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.matricula)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.nombre)
                            </td>
                            <td align="center">

                                <div>
                                    <form class="form-horizontal" role="form" action="../BenefiAdmin/EliminaBeneficiario" method="POST">
                                        <input type="hidden" id="update" name="update" value="@Html.DisplayFor(modelItem => item.curp)" />
                                        <button data-toggle="tooltip" title=" " type="submit" class="btn botonf gira  btnDanger btn-circle">
                                            <i class="glyphicon glyphicon-trash"></i>
                                        </button>
                                    </form>
                                </div>

                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </section>
</body>


