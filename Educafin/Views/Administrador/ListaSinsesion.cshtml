
@model List<Educafin.Models.BeneficiarioSinsesion>

@{
    ViewBag.Title = "Listasinsesion";
}

<section class="container form-horizontal ">
    <div class="col-sm-11 col-sm-offset-1">
        <div class="form-group ">
            <div class="text-left ">
                <h1>Beneficiarios</h1>
                <h2>sin sesión</h2>
            </div>
        </div>

        <div class="form-group">
            
            <div class="col-sm-4">
                <button type="submit" class="btn botonM btnPrimary btn-lg btn-block" onclick="location.href='@Url.Action("DownloadBeneficiario", "Administrador",new {id=(string)Session["pertenece"] })';">
                    <span class="glyphicon glyphicon-save"></span> Descargar Lista
                </button>

            </div>

            
        </div>


        <div class="form-group">

            <table id="tabladatos" class="display" cellspacing="0" width="100%">
                <thead>
                    <tr class="bakinfo">
                        <td width="10%">
                            <h4>No.</h4>
                        </td>

                        <td width="45%">
                            <h4>CURP</h4>
                        </td>
                        <td width="45%">
                            <h4>Correo</h4>
                        </td>
                        <td width="45%">
                            <h4>Contraseña</h4>
                        </td>
                        
                    </tr>
                </thead>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.no)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.curp)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.correo)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.password)
                        </td>
                       
                    </tr>
                }
            </table>
        </div>
    </div>
</section>
