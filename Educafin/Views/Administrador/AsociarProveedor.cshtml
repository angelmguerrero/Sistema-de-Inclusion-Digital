
@model List<Educafin.Models.Proveedor_Institucion>

@{
    ViewBag.Title = "Create";
    string rfc = ViewBag.rfc_prov;
    string nombre = ViewBag.nombre;

    int i = 0;
}


<section class="container form-horizontal ">
    <div class="col-sm-11 col-sm-offset-1">
        <div class="form-group ">
            <div class="text-left ">
                <h2>Proveedor: @nombre</h2>
            </div>
        </div>
        <div class="@TempData["error"]"> @Html.Raw(TempData["Message"])</div>
        <div class="form-horizontal">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
                <div class="form-group">
                    <input type="hidden" name="rfc" value=@rfc />
                    <div class="col-sm-4">
                        <label class="control-label">Institución (CCT):</label>
                        <input type="text" class="form-control" name="cct" id="AuProvIns" placeholder="">
                        <input id="tags" style="border:none" readonly="readonly">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })


                        @foreach (var item in Model)
                        {

                            @Html.ValidationMessageFor(model => item.cct_int, "", new { @class = "text-danger" })

                        }
                    </div>
                    <div class="col-sm-3 ">
                        <label class="control-label">Cantidad:</label>
                        <input type="number" class="form-control" name="cantidad" id="cantidad" placeholder="" min="0" required>

                        <input type="hidden" name="consulta" id="consulta" value="insertar" />
                    </div>
                    <div class="col-sm-3">
                        <button type="submit" class="btn botonM btnPrimary btn-lg btn-block"><span class="glyphicon glyphicon-ok"></span> Asociar</button>
                    </div>
                </div>

            }
            </div>

            <div class="form-group">

                <table width=100% class="table col-sm-12 table-hover table-condensed table-striped" id="tablaLista" align="left">
                    <thead>
                        <tr class="bakinfo">
                            <td width="13.5%">
                                <h4>No.</h4>

                            </td>
                            <td width="18.5%">
                                <h4>CCT</h4>

                            </td>
                            <td width="33.5%">
                                <h4>Nombre</h4>

                            </td>
                            <td width="23.5%">
                                <h4>Cantidad</h4>


                            </td>
                            <td width="10%"></td>
                            <td width="10%"></td>
                        </tr>
                    </thead>


                    @foreach (var item in Model)
            {

                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.no)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.cct_int)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.nombre)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.cantidad)
                            </td>

                            <td>
                            <td align="center">

                                <form method="post" action="">
                                    <input type="hidden" name="rfc" id="rfc" value=@rfc />
                                    <input type="hidden" name="cct" id="cct" value=@item.cct_int />
                                    <input type="hidden" name="consulta" id="consulta" value="borrar" />

                                    <button data-toggle="tooltip" title="" type="submit" class="btn botonf gira  btnDanger btn-circle">
                                        <i class="glyphicon glyphicon-trash"></i>
                                    </button>
                                    </form>


</td>
                        </tr>
                    }

                </table>

            </div>
        </div>
   
</section>








