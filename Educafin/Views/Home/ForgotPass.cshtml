

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Forgot Password";
}
<section class="container form-horizontal ">
    <div class="col-sm-11 col-sm-offset-1">
        <div class="form-group ">
            <div class="text-left ">
                <h1>sistema de Inclusión digital</h1>
                <h2>Recuperación de contraseña</h2>
                <label>*Ingresa tu curp y tu correo para recuperar tu contraseña</label>
            </div>
        </div>
        <form class="form-horizontal col-sm-offset-1" role="form" action="../Home/RecoverPass" method="POST">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <div class="form-group">
                <div class="col-md-4">
                    <label class="control-label">CURP:</label>
                    <input type="text" class="form-control" name="curp" id="curp" placeholder="CURP">
                </div>
            </div>
            <div class="form-group">

                <div class="col-md-4">
                    <label class="control-label">Correo:</label>
                    <input type="text" class="form-control" name="email" id="email" placeholder="email">
                </div>

                <div class="col-sm-3 col-sm-offset-2">
                    <button type="submit" class="btn botonM btnPrimary btn-lg btn-block"><span class="glyphicon glyphicon-ok"></span> Recuperar</button>
                </div>
            </div>

        </form>
    </div>
</section>